{
  "name": "gustavo-palhares-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run content:validate && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "content:validate": "node --experimental-strip-types scripts/content-validate.ts",
    "test": "npm run test:content",
    "test:content": "vitest run tests/content",
    "validate": "npm run check && npm run lint && npm run format:check && npm run test:content && npm run content:validate && npm run build"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@astrojs/mdx": "7.0.3",
    "@fontsource-variable/ibm-plex-sans": "5.3.0",
    "@fontsource-variable/newsreader": "5.3.0",
    "@mdx-js/mdx": "3.1.1",
    "astro": "7.1.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.1",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
