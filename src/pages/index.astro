---
import { siteConfig } from "../config/site.ts";
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicRoutes } from "../lib/routes/public.ts";
import { configuredSiteUrl } from "../lib/seo/site-url.ts";
import { websiteStructuredData } from "../lib/seo/structured-data.ts";

const structuredData = websiteStructuredData(configuredSiteUrl());
---

<BaseLayout
  description={siteConfig.description}
  variant="provisional"
  robots="index, follow"
  structuredData={structuredData}
>
  <section class="provisional-home" aria-labelledby="titulo-inicio">
    <p class="type-label">{siteConfig.shortIdentity}</p>
    <h1 id="titulo-inicio">{siteConfig.name}</h1>
    <div class="provisional-home__body type-intro">
      <p>Esta publicação está em construção.</p>
      <nav class="page-paths type-nav" aria-label="Caminhos disponíveis">
        <a class="link-editorial" href={publicRoutes.sobre}>Sobre</a>
        <a class="link-editorial" href={publicRoutes.contato}>Contato</a>
      </nav>
    </div>
  </section>
</BaseLayout>
