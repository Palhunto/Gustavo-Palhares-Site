---
import { getCollection } from "astro:content";
import IndexLayout from "../../layouts/IndexLayout.astro";
import {
  buildInstant,
  isInPublicCirculation,
} from "../../lib/content/publication.ts";
import { publicRoutes } from "../../lib/routes/public.ts";
import { configuredSiteUrl } from "../../lib/seo/site-url.ts";
import { collectionPageStructuredData } from "../../lib/seo/structured-data.ts";

const at = buildInstant();
const introduction =
  "Edições preservam composições editoriais publicadas como documentos permanentes.";
const entries = (await getCollection("edicoes")).filter((entry) =>
  isInPublicCirculation(entry, at),
);
const structuredData = collectionPageStructuredData(
  configuredSiteUrl(),
  publicRoutes.edicoesIndex,
  "Edições",
  introduction,
);
---

<IndexLayout
  title="Edições"
  introduction={introduction}
  count={entries.length}
  emptyMessage="Ainda não há uma edição editorial aprovada para publicação."
  family="edicoes"
  structuredData={structuredData}
>
  <ol class="family-list" role="list">
    {
      entries.map((entry) => (
        <li>
          <a href={publicRoutes.edicao(entry.data.number)}>
            {entry.data.title}
          </a>
        </li>
      ))
    }
  </ol>
</IndexLayout>
