---
import { siteConfig } from "../../config/site.ts";
import { publicRoutes } from "../../lib/routes/public.ts";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const normalizedPath = currentPath.endsWith("/")
  ? currentPath
  : `${currentPath}/`;
const isCurrent = (href: string) =>
  normalizedPath === href ||
  (href !== publicRoutes.home && normalizedPath.startsWith(href));
---

<header class="site-header">
  <a
    class="site-identity"
    href={publicRoutes.home}
    aria-label="Gustavo Palhares — início"
  >
    <span class="site-identity__name">{siteConfig.name}</span>
    <span class="site-identity__role">{siteConfig.shortIdentity}</span>
  </a>

  <nav class="site-header__nav type-nav" aria-label="Navegação principal">
    <ul role="list">
      {
        siteConfig.navigation.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
