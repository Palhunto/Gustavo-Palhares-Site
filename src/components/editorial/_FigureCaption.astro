---
import type { ResolvedEditorialMedia } from "../../lib/media/index.ts";

interface Props {
  media: ResolvedEditorialMedia;
  number?: string;
  showCredit?: boolean;
}

const { media, number, showCredit = true } = Astro.props;
---

{
  (number !== undefined ||
    media.caption ||
    (showCredit && media.credit.name)) && (
    <figcaption
      class:list={[
        "editorial-caption type-caption",
        { "editorial-caption--indexed": number !== undefined },
      ]}
    >
      {number !== undefined && (
        <span class="editorial-caption__index editorial-photo-number number-stable">
          {number}
        </span>
      )}
      {media.caption && <span>{media.caption}</span>}
      {showCredit && (
        <span class="editorial-caption__credit">
          {media.credit.role}: {media.credit.name}
        </span>
      )}
    </figcaption>
  )
}
